{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auctions-read": {
        "ClusterId": "auction-cluster",
        "Match": {
          "Path": "/api/auctions/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "auctions-write": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/auctions/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE" ]
        }
      },
      "search": {
        "ClusterId": "search-cluster",
        "Match": {
          "Path": "/api/search/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "bidWrite": {
        "ClusterId": "bids-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/bids",
          "Methods": [ "POST" ]
        }
      },
      "bidRead": {
        "ClusterId": "bids-cluster",
        "Match": {
          "Path": "/api/bids/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "notification": {
        "ClusterId": "notification-cluster",
        "CorsPolicy": "customPolicy",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auction-cluster": {
        "Destinations": {
          "auction-api": {
            "Address": "http://auction-service-clusterip"
          }
        }
      },
      "search-cluster": {
        "Destinations": {
          "search-api": {
            "Address": "http://search-service-clusterip"
          }
        }
      },
      "bids-cluster": {
        "Destinations": {
          "bids-api": {
            "Address": "http://bids-service-clusterip"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-websocket": {
            "Address": "http://noti-service-clusterip"
          }
        }
      }
    }
  }
}