{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ClientApp" : "http://localhost:3000",
  "ReverseProxy": {
    "Routes": {
      "auctions-read": {
        "ClusterId": "auction-cluster",
        "Match": {
          "Path": "/auctions/{**catch-all}",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/api/auctions/{**catch-all}"
          }
        ]
      },
      "auctions-write": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/auctions/{**catch-all}",
          "Methods": [
            "POST",
            "PUT",
            "DELETE"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/api/auctions/{**catch-all}"
          }
        ]
      },
      "search": {
        "ClusterId": "search-cluster",
        "Match": {
          "Path": "/search/{**catch-all}",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/api/search/{**catch-all}"
          }
        ]
      },
      "bidWrite": {
        "ClusterId": "bids-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/bids",
          "Methods": [
            "POST"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/api/bids"
          }
        ]
      },
      "bidRead": {
        "ClusterId": "bids-cluster",
        "Match": {
          "Path": "/bids/{**catch-all}",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathPattern": "/api/bids/{**catch-all}"
          }
        ]
      },
      "notification": {
        "ClusterId": "notification-cluster",
        "CorsPolicy": "customPolicy",
        "Match": {
          "Path": "/notification/{**catch-all}"
        }
      }
    }
  }
}
